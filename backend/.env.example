# ── Lemon Squeezy (Merchant of Record — handles EU VAT for you) ────────────────
# Sign up free at lemonsqueezy.com — no monthly fees, ~5% per transaction
# They are the legal seller, you receive creator payouts. Safe to use before registering as autónoma.
LS_API_KEY=your_api_key_here            # Settings → API
LS_WEBHOOK_SECRET=your_secret_here     # Settings → Webhooks
LS_STORE_ID=your_store_id_here         # visible in your store URL
LS_PRO_VARIANT_ID=your_variant_id      # the variant ID of your €4/month product

# ── App config ─────────────────────────────────────────────────────────────────
APP_DOMAIN=http://localhost:3000
# In production: APP_DOMAIN=https://tubesum.dehesa.dev

# ── Brevo (transactional emails: welcome, password reset, password changed) ──
# We use Brevo's HTTPS API (port 443) instead of SMTP because Railway blocks
# outbound SMTP (ports 25/465/587). Free tier: 300 emails/day, no per-recipient
# restriction. Domain dehesa.dev must be authenticated in Brevo (SPF + DKIM +
# DMARC records) so from-addresses tubesum@dehesa.dev and noreply@dehesa.dev
# pass authentication.
# If BREVO_API_KEY is unset, emails are skipped (dev-safe, logs a warning).
BREVO_API_KEY=                          # xkeysib-xxxxxxxxxxxxxxxxxxxxxxxx (Brevo → SMTP & API → API Keys)
