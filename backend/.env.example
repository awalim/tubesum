# ── Lemon Squeezy (Merchant of Record — handles EU VAT for you) ────────────────
# Sign up free at lemonsqueezy.com — no monthly fees, ~5% per transaction
# They are the legal seller, you receive creator payouts. Safe to use before registering as autónoma.
LS_API_KEY=your_api_key_here            # Settings → API
LS_WEBHOOK_SECRET=your_secret_here     # Settings → Webhooks
LS_STORE_ID=your_store_id_here         # visible in your store URL
LS_PRO_VARIANT_ID=your_variant_id      # the variant ID of your €4/month product

# ── App config ─────────────────────────────────────────────────────────────────
APP_DOMAIN=http://localhost:3000
# In production: APP_DOMAIN=https://tubesum.yourdomain.com
